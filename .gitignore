# ──────────────────────────────────────────────────────────────────────────────
# node / pnpm / turborepo
# ──────────────────────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/
.pnpm-debug.log*
pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.turbo/

# ──────────────────────────────────────────────────────────────────────────────
# typescript / build output
# ──────────────────────────────────────────────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
coverage/
*.tsbuildinfo

# ──────────────────────────────────────────────────────────────────────────────
# env / secrets — never commit. keep .env.example so the shape is shared.
# Doppler CLI state lives in ~/.doppler; the in-repo `doppler.yaml` IS meant
# to be committed (it's project config, not secrets).
# ──────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
.doppler/
*.pem
*.key
secrets/

# ──────────────────────────────────────────────────────────────────────────────
# docker / postgres local volumes
# ──────────────────────────────────────────────────────────────────────────────
docker-data/
postgres-data/
pgdata/
.postgres/
*.sqlite
*.sqlite-journal

# ──────────────────────────────────────────────────────────────────────────────
# temporal local state (temporal server start-dev writes here)
# ──────────────────────────────────────────────────────────────────────────────
.temporal/
temporal.db
temporal-data/

# ──────────────────────────────────────────────────────────────────────────────
# playwright
# ──────────────────────────────────────────────────────────────────────────────
test-results/
playwright-report/
playwright/.cache/
blob-report/

# ──────────────────────────────────────────────────────────────────────────────
# logs / misc runtime
# ──────────────────────────────────────────────────────────────────────────────
*.log
logs/
pids/
*.pid
*.seed

# ──────────────────────────────────────────────────────────────────────────────
# OS cruft
# ──────────────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# ──────────────────────────────────────────────────────────────────────────────
# IntelliJ / JetBrains — ignore wholesale; shared tooling (eslint, tsconfig,
# prettier, editorconfig) lives at the repo root, not inside .idea/.
# ──────────────────────────────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr

# ──────────────────────────────────────────────────────────────────────────────
# Cursor — do NOT ignore `.cursor/` wholesale: `.cursor/rules/*.mdc` and
# `.cursor/mcp.json` are intentionally committed shared config. Only ignore
# Cursor's local/session state.
# ──────────────────────────────────────────────────────────────────────────────
.cursor/logs/
.cursor/cache/
.cursorignore.local

# ──────────────────────────────────────────────────────────────────────────────
# Claude Code — `.claude/settings.json`, `.claude/skills/`, `.claude/commands/`,
# `.claude/agents/` are committed (shared). `settings.local.json` and local
# caches are not.
# ──────────────────────────────────────────────────────────────────────────────
.claude/settings.local.json
.claude/cache/
.claude/logs/

# ──────────────────────────────────────────────────────────────────────────────
# opencode (agent harness) — local config/state only; share opencode.json
# at the repo root if/when it exists.
# ──────────────────────────────────────────────────────────────────────────────
.opencode/
opencode.local.json

# ──────────────────────────────────────────────────────────────────────────────
# misc editor / agent local files
# ──────────────────────────────────────────────────────────────────────────────
.aider*
.vscode/*.local.json
*.swp
*.swo
*~
